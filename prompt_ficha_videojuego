  "allOf": [
    {
      "if": {
        "properties": {
          "formato": {
            "const": "Big Box"
          }
        }
      },
      "then": {
        "properties": {
          "serie": {
            "contains": {
              "const": "Big Box"
            }
          },
          "url": {
            "pattern": "-bigbox\\/$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "formato": {
            "const": "DVD Case"
          }
        }
      },
      "then": {
        "properties": {
          "serie": {
            "contains": {
              "const": "DVD Case"
            }
          },
          "url": {
            "pattern": "-cddvd\\/$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "formato": {
            "const": "Jewel Case"
          }
        }
      },
      "then": {
        "properties": {
          "serie": {
            "contains": {
              "const": "Jewel Case"
            }
          },
          "url": {
            "pattern": "-jewelcase\\/$"
          }
        }
      }
    }
  ]
}
